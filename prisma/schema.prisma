  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  acceptance ScanAcceptance? @relation(fields: [acceptanceId], references: [id])
  requestedBy User? @relation("ScanRetakeRequestedBy", fields: [requestedById], references: [id])

