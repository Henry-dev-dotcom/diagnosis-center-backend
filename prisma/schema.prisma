model Invoice {
  id          String @id @default(cuid())
  invoiceCode String @unique
  orderId     String? @unique
  patientId   String
  hospitalId  String?
  status      InvoiceStatus @default(UNPAID)
  subtotal    Decimal @default(0) @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  tax         Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @default(0) @db.Decimal(12, 2)
  amountPaid  Decimal @default(0) @db.Decimal(12, 2)
  balance     Decimal @default(0) @db.Decimal(12, 2)
  insuranceClaimRef String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order Order? @relation(fields: [orderId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])
  hospital Hospital? @relation(fields: [hospitalId], references: [id])
  createdBy User? @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  items InvoiceItem[]
  payments Payment[]

  @@index([patientId])
  @@index([hospitalId])
  @@index([status])
  @@index([createdAt])
}

model InvoiceItem {
  id          String @id @default(cuid())
  invoiceId   String
  catalogItemId String?
  orderItemId String?
  description String
  quantity    Int @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem? @relation(fields: [catalogItemId], references: [id])
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])

  @@index([invoiceId])
  @@index([catalogItemId])
  @@index([orderItemId])
}

model Payment {
  id          String @id @default(cuid())
  paymentCode String @unique
  invoiceId   String
  shiftId     String?
  receivedById String?
  method      PaymentMethod
  status      PaymentStatus @default(COMPLETED)
  amount      Decimal @db.Decimal(12, 2)
  reference   String?
  note        String?
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  shift CashierShift? @relation(fields: [shiftId], references: [id])
  receivedBy User? @relation("PaymentReceivedBy", fields: [receivedById], references: [id])
  floatTransactions FloatTransaction[]
  ledgerEntries LedgerEntry[]
  receipt Receipt?

  @@index([invoiceId])
  @@index([shiftId])
  @@index([method])
  @@index([createdAt])
}

model CashierShift {
  id          String @id @default(cuid())
  shiftCode   String @unique
  userId      String
  type        String
  status      ShiftStatus @default(OPEN)
  openingFloat Decimal @default(0) @db.Decimal(12, 2)
  expectedCash Decimal @default(0) @db.Decimal(12, 2)
  countedCash  Decimal? @db.Decimal(12, 2)
  variance     Decimal? @db.Decimal(12, 2)
  startNotes   String?
  closeNotes   String?
  startedAt    DateTime @default(now())
  closedAt     DateTime?

  user User @relation("CashierShiftUser", fields: [userId], references: [id])
  payments Payment[]
  floatTransactions FloatTransaction[]

  @@index([userId])
  @@index([status])
  @@index([startedAt])
}

model FloatTransaction {
  id          String @id @default(cuid())
